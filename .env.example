# ==============================================
# en-practice-be — EC2 Production Environment
# Copy this file to .env and fill in real values
# DO NOT commit .env to version control!
# ==============================================

# ---- Docker Hub Image ----
DOCKER_HUB_IMAGE=
APP_VERSION=

# ---- App Port (exposed on EC2) ----
APP_PORT=8080

# ---- PostgreSQL ----
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---- JWT ----
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRATION=604800000

# ---- Firebase Admin SDK ----
# Base64 encode your firebase service account JSON:
#   cat firebase-service-account.json | base64 -w 0
FIREBASE_CONFIG_BASE64=

# ---- OpenClaw Gateway ----
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# ---- Google Cloud TTS ----
TTS_API_KEY=
TTS_VOICE_NAME=en-US-Neural2-J
TTS_LANGUAGE_CODE=en-US

# ---- Backblaze S3 ----
BACKBLAZE_S3_ENDPOINT=
BACKBLAZE_S3_REGION=
BACKBLAZE_S3_ACCESS_KEY_ID=
BACKBLAZE_S3_SECRET_ACCESS_KEY=
BACKBLAZE_S3_BUCKET_NAME=
BACKBLAZE_S3_WORKER_SHARED_SECRET=

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=

# ---- Custom Speaking Conversation ----
CUSTOM_SPEAKING_CONVERSATION_MAX_USER_TURNS=100
